{
  "name": "@anter/anter-adapter",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "pnpm run clean && tsup && tsc -p tsconfig.build.json",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "@anter/ai-chat-sdk": "*"
  },
  "devDependencies": {
    "@anter/ai-chat-sdk": "workspace:*",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.0",
    "typescript": "^6.0.2"
  }
}
